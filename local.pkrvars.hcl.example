# Copy this file to local.pkrvars.hcl and fill in your values.
# DO NOT commit the populated file — it is listed in .gitignore.

# Path to a Rocky Linux 9 KVM guest image (QCOW2).
# Download from: https://rockylinux.org/download (Generic Cloud / Base image)
# Use an absolute path — Packer's file() function does not expand ~.
source_image_path = "/Users/you/Downloads/Rocky-9-GenericCloud-Base.latest.x86_64.qcow2"

# SSH keypair used during provisioning.
# The public key is injected into the VM via cloud-init; Packer connects with the private key.
# Use absolute paths — Packer's file() function does not expand ~.
ssh_public_key_file  = "/Users/you/.ssh/id_ed25519.pub"
ssh_private_key_file = "/Users/you/.ssh/id_ed25519"

# SSH username in the source cloud image (default: rocky for Rocky Linux cloud images).
ssh_username = "rocky"

# Output image name prefix (a timestamp is appended automatically).
image_name_prefix = "rocky9-cis-l2-local"

# Directory to write the finished QCOW2 image to.
output_dir = "output-local"

# QEMU accelerator: "kvm" on Linux, "hvf" on macOS.
accelerator = "kvm"

# Build VM resources.
memory    = 2048
cpus      = 2
disk_size = 20480
